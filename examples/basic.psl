// 基础语法示例：单行/多行报文、协议层、简单负载
// 单行报文（省略中括号）
eth(dst=00:11:22:33:44:55, src=66:77:88:99:AA:BB) ip(src=192.168.1.1, dst=192.168.1.2) tcp(sport=1234, dport=80) `GET / HTTP/1.1`

// 多行报文（必须加中括号）
[
  eth()
  ip(ttl=64, src=10.0.0.1,dst=192.168.1.2)
  udp(sport=5678, dport=9012)
  `x 001122334455`
]
@repeat 3
@interval 500ms

// 空字段协议层
//[arp(sha=) icmp()] @repeat 1