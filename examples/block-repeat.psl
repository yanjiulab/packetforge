// 普通块（非 async）+ @repeat：块内多报文顺序执行，整体重复（显式填写非默认字段）
{
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02) ip(src=192.168.1.1, dst=192.168.1.2) udp(sport=1000, dport=2000) `first`
  [
    eth(dst=00:50:56:00:00:02, src=00:50:56:00:00:01)
    ip(src=192.168.1.2, dst=192.168.1.1)
    tcp(sport=3000, dport=80)
    `second`
  ]
}
@repeat 2
@interval 500ms
