// $inc / $seq 示例：repeat 时 ip.id 递增，作用域为当前报文语句的 repeat
// $inc(step) = 0, step, 2*step, ...  ；$seq(start, step) = start, start+step, ...
[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02, type=0x0800)
  ip(src=192.168.1.1, dst=192.168.1.2, id=$inc(10))
  udp(sport=50000, dport=50000)
  `ping`
] @repeat 5

{
  [
    eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02, type=0x0800)
    ip(src=192.168.2.1, dst=192.168.2.2, id=$seq(10,100))
    udp(sport=50000, dport=50000)
    `ping`
  ] @repeat 5
  [
    eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02, type=0x0800)
    ip(src=192.168.3.1, dst=192.168.3.2, id=$seq(10,1000))
    udp(sport=50000, dport=50000)
    `ping`
  ] @repeat 5
}
@repeat 5