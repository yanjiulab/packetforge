// 多个单报文语句，无块、无 async；单行可省略中括号，显式填写非默认字段
eth(dst=00:11:22:33:44:55, src=66:77:88:99:AA:BB) ip(src=1.1.1.1, dst=2.2.2.2) tcp(sport=1234, dport=80) `one`

[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=10.0.0.1, dst=10.0.0.2, ttl=32)
  udp(sport=9999, dport=9999)
  `x deadbeef`
]

[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=10.0.0.1, dst=10.0.0.2)
  icmp()
  `ping`
]
