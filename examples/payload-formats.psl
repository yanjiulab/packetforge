// 多种负载格式：字符串、十六进制、二进制、Base64（中括号内包含负载，显式填写 ip/tcp/udp 必填字段）
[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=192.168.1.1, dst=192.168.1.2)
  udp(sport=1000, dport=2000)
  `plain text`
]

[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=192.168.1.1, dst=192.168.1.2)
  udp(sport=1001, dport=2001)
  `x 0001020304050607`
]

[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=192.168.1.1, dst=192.168.1.2)
  udp(sport=1002, dport=2002)
  `b 00000000 11111111`
]

[
  eth(dst=00:50:56:00:00:01, src=00:50:56:00:00:02)
  ip(src=192.168.1.1, dst=192.168.1.2)
  data()
  `64 SGVsbG8gV29ybGQ=`
]
